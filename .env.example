# ============================================================================
# Copy this file to .env and fill in GROQ_API_KEY.  Everything else has
# working local defaults matching docker-compose.yml.
# NEVER commit the real .env file.
# ============================================================================

# --- Groq LLM (the only cloud dependency in Stage 1) ---
GROQ_API_KEY=put-your-groq-key-here
GROQ_MODEL=openai/gpt-oss-120b

# --- Gemini fallback (optional) ---
# Used automatically only when Groq is rate-limited/unavailable. Leave blank
# to disable the fallback. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Neo4j (docker-compose local) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smartoffice123

# --- Weaviate (docker-compose local) ---
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# --- Embeddings (local, free, no key needed) ---
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# --- Backend behaviour ---
CORS_ORIGINS=http://localhost:3000
HASH_STORE_PATH=./data/ingest_manifest.sqlite
ENABLE_GRAPH_ENRICHMENT=true          # LLM entity extraction into Neo4j (costs tokens)
LOG_LEVEL=INFO

# --- Frontend (read by Next.js; must start with NEXT_PUBLIC_) ---
# Baked in at build time; the compose file passes it as a build arg.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Retrieval / re-ranking (optional tuning; defaults are sensible) ---
# Cross-encoder re-ranking reorders retrieved evidence by true relevance.
RERANK_ENABLED=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RETRIEVAL_TOP_K=5
MAX_EVIDENCE=10
RERANK_CANDIDATE_POOL=20

# --- Semantic chunking (optional tuning) ---
CHUNK_BREAKPOINT_PERCENTILE=95
CHUNK_BUFFER_SIZE=1

# --- Enrichment (optional tuning) ---
EXTRACTION_CHAR_LIMIT=6000
EMBED_BATCH_SIZE=16
