# ============================================================================
# Copy this file to .env and fill in XAI_API_KEY and GROQ_API_KEY.
# Everything else has working local defaults matching docker-compose.yml.
# NEVER commit the real .env file.
#
# SECURITY NOTE: the keys previously in this file were real, live secrets.
# They must be rotated (Groq console, Google AI Studio) before use — do not
# reuse the old values. Placeholders below.
# ============================================================================

# --- xAI Grok LLM (primary; REQUIRED — config.py fails startup without it) ---
XAI_API_KEY=replace_with_your_xai_api_key
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1

# --- Groq LLM (fallback for /chat generation; ALSO REQUIRED — used
# unconditionally by the router's LLM-fallback classifier and by graph
# enrichment extraction, regardless of which provider answers /chat) ---
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Neo4j (docker-compose local) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smartoffice123

# --- Weaviate (docker-compose local) ---
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# --- Embeddings (local, free, no key needed) ---
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# --- Backend behaviour ---
CORS_ORIGINS=http://localhost:3000
HASH_STORE_PATH=./data/ingest_manifest.sqlite
ENABLE_GRAPH_ENRICHMENT=true          # LLM entity extraction into Neo4j (costs tokens)
LOG_LEVEL=INFO

# --- Frontend (read by Next.js; must start with NEXT_PUBLIC_) ---
# Baked in at build time; the compose file passes it as a build arg.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Retrieval / re-ranking (optional tuning; defaults are sensible) ---
# Hybrid search fuses dense (vector/semantic) and sparse (BM25/keyword)
# scoring in one Weaviate call, so exact model numbers / error codes are
# matched even when the embedding under-weights them. alpha=1.0 pure vector,
# alpha=0.0 pure BM25, 0.5 = equal weight.
HYBRID_SEARCH_ENABLED=true
HYBRID_SEARCH_ALPHA=0.5

# Cross-encoder re-ranking reorders retrieved evidence by true relevance.
RERANK_ENABLED=false
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RETRIEVAL_TOP_K=5
MAX_EVIDENCE=10
RERANK_CANDIDATE_POOL=20

# --- Semantic chunking (optional tuning) ---
CHUNK_BREAKPOINT_PERCENTILE=95
CHUNK_BUFFER_SIZE=1

# --- Enrichment (optional tuning) ---
EXTRACTION_CHAR_LIMIT=6000
# Pacing delay between graph-enrichment LLM calls. 0 = no pacing. Raise this
# if ingesting a manual with many chunks trips 429s on your Groq/xAI tier.
EXTRACTION_CALL_DELAY_SECONDS=0
EMBED_BATCH_SIZE=16

# --- Router thresholds (optional tuning) ---
ROUTER_RULE_MARGIN_THRESHOLD=0.25
ROUTER_FALLBACK_CONF_THRESHOLD=0.60

# --- Graph retrieval limits (optional tuning) ---
GRAPH_MAX_FACTS=15
GRAPH_NEIGHBOR_LIMIT=10
GRAPH_INCIDENT_LIMIT=10
GRAPH_ENRICHMENT_LIMIT=8

# --- Retrieval cache (optional) ---
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_SIZE=256

# --- Rate limiting (optional) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_WRITE=10/minute
RATE_LIMIT_DEFAULT=120/minute
