# =============================================================================
# FacilityGraph AI — Environment Configuration Example
#
# Copy this file before running the project:
#   cp .env.example .env
#
# Never commit the real .env file or real API keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Primary LLM — Groq
# Required for AI-generated answers.
# Replace the placeholder with your real key inside .env only.
# -----------------------------------------------------------------------------
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b

# -----------------------------------------------------------------------------
# Optional fallback LLM — Gemini
# Leave GEMINI_API_KEY empty to disable the fallback.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Neo4j
# Docker Compose overrides NEO4J_URI internally with bolt://neo4j:7687.
# The localhost value supports running backend tools outside Docker.
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smartoffice123

# -----------------------------------------------------------------------------
# Weaviate
# Docker Compose uses the internal service name inside containers.
# These localhost values support local scripts outside Docker.
# -----------------------------------------------------------------------------
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# Embeddings and graph enrichment
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
ENABLE_GRAPH_ENRICHMENT=true

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
