# =============================================================================
# FacilityGraph AI — Environment Configuration Example
#
# Copy this file before running the project:
#   cp .env.example .env
#
# Never commit the real .env file or real API keys.
# =============================================================================

# Primary LLM — xAI
XAI_API_KEY=replace_with_your_xai_api_key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.5

# Fallback LLM — Groq
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# -----------------------------------------------------------------------------
# Neo4j
# Docker Compose overrides NEO4J_URI internally with bolt://neo4j:7687.
# The localhost value supports running backend tools outside Docker.
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smartoffice123

# -----------------------------------------------------------------------------
# Weaviate
# Docker Compose uses the internal service name inside containers.
# These localhost values support local scripts outside Docker.
# -----------------------------------------------------------------------------
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# Embeddings and graph enrichment
# -----------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
ENABLE_GRAPH_ENRICHMENT=true

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
HASH_STORE_PATH=./data/ingest_manifest.sqlite
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Retrieval and reranking tuning
# -----------------------------------------------------------------------------
HYBRID_SEARCH_ENABLED=true
HYBRID_SEARCH_ALPHA=0.5
RERANK_ENABLED=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RETRIEVAL_TOP_K=5
MAX_EVIDENCE=10
RERANK_CANDIDATE_POOL=20

# -----------------------------------------------------------------------------
# Semantic chunking and enrichment tuning
# -----------------------------------------------------------------------------
CHUNK_BREAKPOINT_PERCENTILE=95
CHUNK_BUFFER_SIZE=1
EXTRACTION_CHAR_LIMIT=6000
EMBED_BATCH_SIZE=16

# -----------------------------------------------------------------------------
# Router and graph retrieval tuning
# -----------------------------------------------------------------------------
ROUTER_RULE_MARGIN_THRESHOLD=0.25
ROUTER_FALLBACK_CONF_THRESHOLD=0.60
GRAPH_MAX_FACTS=15
GRAPH_NEIGHBOR_LIMIT=10
GRAPH_INCIDENT_LIMIT=10
GRAPH_ENRICHMENT_LIMIT=8

# -----------------------------------------------------------------------------
# Retrieval cache and rate limits
# -----------------------------------------------------------------------------
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_SIZE=256
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_DEFAULT=120/minute
